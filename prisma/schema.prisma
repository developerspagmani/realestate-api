generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                    String               @id @default(uuid()) @db.Uuid
  name                  String
  type                  Int
  domain                String?              @unique
  status                Int                  @default(1)
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  address               String?
  city                  String?
  country               String?
  postalCode            String?              @map("postal_code")
  state                 String?
  website               String?
  settings              Json?                @default("{}")
  planId                String?              @map("plan_id") @db.Uuid
  subscriptionStatus    Int                  @default(1)
  subscriptionExpiresAt DateTime?            @map("subscription_expires_at")
  agents                Agent[]
  amenities             Amenity[]
  audienceGroups        AudienceGroup[]
  auditLogs             AuditLog[]
  bookings              Booking[]
  campaignLogs          CampaignLog[]
  campaigns             Campaign[]
  commissions           Commission[]
  connectedAccounts     ConnectedAccount[]
  emailTemplates        EmailTemplate[]
  formBuilders          FormBuilder[]
  integrations          Integration[]
  leadInteractions      LeadInteraction[]
  leads                 Lead[]
  lostLeads             LeadLossData[]
  licenseKey            LicenseKey?
  listings              Listing[]
  marketingWorkflows    MarketingWorkflow[]
  media                 Media[]
  pages                 Page[]
  payments              Payment[]
  upgradeRequests       PlanUpgradeRequest[]
  properties            Property[]
  propertyCategories    PropertyCategory[]
  publishedPosts        PublishedPost[]
  scheduledPosts        ScheduledPost[]
  tenantModules         TenantModule[]
  plan                  Plan?                @relation(fields: [planId], references: [id])
  units                 Unit[]
  userPropertyAccess    UserPropertyAccess[]
  users                 User[]
  websites              Website[]
  whatsappCampaigns     WhatsAppCampaign[]
  whatsappMessages      WhatsAppMessage[]
  whatsappTemplates     WhatsAppTemplate[]
  whatsappChatbot       WhatsAppChatbot?
  portalListings        PortalListing[]
  widgets               Widget[]
  workflowLogs          WorkflowLog[]
  tasks                 Task[]

  @@map("tenants")
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  type      String   @default("string")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Plan {
  id              String               @id @default(uuid()) @db.Uuid
  name            String
  slug            String               @unique
  description     String?
  price           Decimal              @db.Decimal(10, 2)
  interval        String               @default("yearly")
  status          Int                  @default(1)
  features        Json?                @default("{}")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  licenseKeys     LicenseKey[]
  upgradeRequests PlanUpgradeRequest[]
  tenants         Tenant[]
  modules         Module[]             @relation("ModuleToPlan")

  @@map("plans")
}

model LicenseKey {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  planId      String    @map("plan_id") @db.Uuid
  status      Int       @default(1)
  tenantId    String?   @unique @map("tenant_id") @db.Uuid
  activatedAt DateTime? @map("activated_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  userId      String?   @map("user_id") @db.Uuid
  plan        Plan      @relation(fields: [planId], references: [id])
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@map("license_keys")
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  tenantId             String?              @map("tenant_id") @db.Uuid
  name                 String?
  email                String               @unique
  phone                String?
  passwordHash         String?              @map("password_hash")
  role                 Int?
  status               Int                  @default(2)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  activationToken      String?              @map("activation_token")
  addressLine1         String?              @map("address_line1")
  addressLine2         String?              @map("address_line2")
  city                 String?
  companyName          String?              @map("company_name")
  country              String?
  firstName            String?              @map("first_name")
  isVerified           Boolean              @default(false) @map("is_verified")
  lastName             String?              @map("last_name")
  resetPasswordExpires DateTime?            @map("reset_password_expires")
  resetPasswordToken   String?              @map("reset_password_token")
  state                String?
  website              String?
  zipCode              String?              @map("zipcode")
  agent                Agent?
  auditLogs            AuditLog[]
  bookings             Booking[]
  connectedAccounts    ConnectedAccount[]
  leads                Lead[]
  licenseKeys          LicenseKey[]
  media                Media[]
  payments             Payment[]
  planUpgradeRequests  PlanUpgradeRequest[]
  publishedPosts       PublishedPost[]
  scheduledPosts       ScheduledPost[]
  userPropertyAccess   UserPropertyAccess[]
  tenant               Tenant?              @relation(fields: [tenantId], references: [id])
  whatsappCampaigns    WhatsAppCampaign[]
  createdTasks         Task[]

  @@index([tenantId])
  @@index([phone])
  @@map("users")
}

model Property {
  id                 String               @id @default(uuid()) @db.Uuid
  tenantId           String?              @map("tenant_id") @db.Uuid
  propertyType       Int?                 @map("property_type")
  title              String?
  description        String?
  addressLine1       String?              @map("address_line1")
  addressLine2       String?              @map("address_line2")
  city               String?
  state              String?
  country            String?
  postalCode         String?              @map("postal_code")
  latitude           Decimal?             @db.Decimal(10, 7)
  longitude          Decimal?             @db.Decimal(10, 7)
  status             Int                  @default(1)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  gallery            Json?
  mainImageId        String?              @map("main_image_id") @db.Uuid
  slug               String?              @unique
  area               Int?                 @map("area")
  bathrooms          Int?
  bedrooms           Int?
  brochureId         String?              @map("brochure_id") @db.Uuid
  floorPlanId        String?              @map("floor_plan_id") @db.Uuid
  listingType        String?              @default("Rent") @map("listing_type")
  lotSize            Int?                 @map("lot_size")
  neighborhood       String?
  parkingSpaces      Int?                 @map("parking_spaces")
  yearBuilt          Int?                 @map("year_built")
  categoryId         String?              @map("category_id") @db.Uuid
  metadata           Json?                @default("{}")
  videoUrl           String?              @map("video_url")
  price              Decimal?             @db.Decimal(15, 2)
  agentProperties    AgentProperty[]
  bookings           Booking[]
  leads              Lead[]
  brochure           Media?               @relation("PropertyBrochure", fields: [brochureId], references: [id])
  category           PropertyCategory?    @relation(fields: [categoryId], references: [id])
  floorPlan          Media?               @relation("PropertyFloorPlan", fields: [floorPlanId], references: [id])
  mainImage          Media?               @relation("PropertyMainImage", fields: [mainImageId], references: [id])
  tenant             Tenant?              @relation(fields: [tenantId], references: [id])
  workspace3D        Property3DConfig?
  propertyAmenities  PropertyAmenity[]
  scheduledPosts     ScheduledPost[]
  units              Unit[]
  userPropertyAccess UserPropertyAccess[]
  websites           Website[]
  portalListings     PortalListing[]
  widgets            Widget[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([status])
  @@index([propertyType])
  @@map("properties")
}

model PropertyCategory {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String?            @map("tenant_id") @db.Uuid
  name        String
  slug        String?
  description String?
  icon        String?            @default("bi-folder")
  parentId    String?            @map("parent_id") @db.Uuid
  sortOrder   Int                @default(0) @map("sort_order")
  status      Int                @default(1)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  properties  Property[]
  parent      PropertyCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    PropertyCategory[] @relation("CategoryHierarchy")
  tenant      Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("property_categories")
}

model PropertyAmenity {
  propertyId String   @map("property_id") @db.Uuid
  amenityId  String   @map("amenity_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

model Unit {
  id                String                 @id @default(uuid()) @db.Uuid
  tenantId          String?                @map("tenant_id") @db.Uuid
  propertyId        String?                @map("property_id") @db.Uuid
  unitCategory      Int                    @map("unit_category")
  unitCode          String?                @map("unit_code")
  floorNo           Int?                   @map("floor_no")
  capacity          Int?
  sizeSqft          Int?                   @map("size_sqft")
  status            Int                    @default(1)
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  gallery           Json?
  mainImageId       String?                @map("main_image_id") @db.Uuid
  slug              String?                @unique
  metadata          Json?                  @default("{}")
  bookings          Booking[]
  leads             Lead[]
  listings          Listing[]
  realEstateDetails RealEstateUnitDetails?
  unitAmenities     UnitAmenity[]
  unitPricing       UnitPricing[]
  mainImage         Media?                 @relation("UnitMainImage", fields: [mainImageId], references: [id])
  property          Property?              @relation(fields: [propertyId], references: [id])
  tenant            Tenant?                @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([unitCategory])
  @@map("units")
}

model UnitPricing {
  id           String   @id @default(uuid()) @db.Uuid
  unitId       String?  @map("unit_id") @db.Uuid
  pricingModel Int?     @map("pricing_model")
  price        Decimal? @db.Decimal(15, 2)
  currency     String?
  createdAt    DateTime @default(now()) @map("created_at")
  unit         Unit?    @relation(fields: [unitId], references: [id])

  @@map("unit_pricing")
}

model RealEstateUnitDetails {
  unitId       String @id @map("unit_id") @db.Uuid
  bedrooms     Int?
  bathrooms    Int?
  furnishing   Int?
  parkingSlots Int?   @map("parking_slots")
  facing       Int?
  unit         Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("real_estate_unit_details")
}

model Amenity {
  id                String            @id @default(uuid()) @db.Uuid
  name              String?
  category          Int?
  icon              String?
  status            Int               @default(1)
  createdAt         DateTime          @default(now()) @map("created_at")
  tenantId          String?           @map("tenant_id") @db.Uuid
  tenant            Tenant?           @relation(fields: [tenantId], references: [id])
  propertyAmenities PropertyAmenity[]
  unitAmenities     UnitAmenity[]

  @@map("amenities")
}

model UnitAmenity {
  unitId    String   @map("unit_id") @db.Uuid
  amenityId String   @map("amenity_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  amenity   Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([unitId, amenityId])
  @@map("unit_amenities")
}

model Booking {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String?      @map("tenant_id") @db.Uuid
  unitId          String?      @map("unit_id") @db.Uuid
  userId          String?      @map("user_id") @db.Uuid
  startAt         DateTime     @map("start_at")
  endAt           DateTime     @map("end_at")
  status          Int          @default(1)
  createdAt       DateTime     @default(now()) @map("created_at")
  notes           String?
  paymentStatus   Int          @default(1) @map("payment_status")
  qrCode          String?      @map("qr_code")
  specialRequests String?      @map("special_requests")
  totalPrice      Decimal?     @map("total_price") @db.Decimal(10, 2)
  updatedAt       DateTime     @updatedAt @map("updated_at")
  agentId         String?      @map("agent_id") @db.Uuid
  guestEmail      String?      @map("guest_email")
  guestName       String?      @map("guest_name")
  guestPhone      String?      @map("guest_phone")
  leadId          String?      @map("lead_id") @db.Uuid
  propertyId      String?      @map("property_id") @db.Uuid
  agent           Agent?       @relation(fields: [agentId], references: [id])
  lead            Lead?        @relation(fields: [leadId], references: [id])
  property        Property?    @relation(fields: [propertyId], references: [id])
  tenant          Tenant?      @relation(fields: [tenantId], references: [id])
  unit            Unit?        @relation(fields: [unitId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])
  commissions     Commission[]
  payments        Payment[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([unitId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model Listing {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String?   @map("tenant_id") @db.Uuid
  unitId         String?   @map("unit_id") @db.Uuid
  slug           String?   @unique
  isPublished    Boolean   @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at")
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  unit           Unit?     @relation(fields: [unitId], references: [id])

  @@map("listings")
}

model Lead {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String?              @map("tenant_id") @db.Uuid
  unitId         String?              @map("unit_id") @db.Uuid
  propertyId     String?              @map("property_id") @db.Uuid
  name           String?
  email          String?
  phone          String?
  message        String?
  source         Int?
  createdAt      DateTime             @default(now()) @map("created_at")
  budget         Decimal?             @db.Decimal(15, 2)
  company        String?
  notes          String?
  preferredDate  DateTime?            @map("preferred_date")
  priority       Int                  @default(2)
  status         Int                  @default(1)
  tags           String?
  updatedAt      DateTime             @default(now()) @updatedAt @map("updated_at")
  userId         String?              @map("user_id") @db.Uuid
  assignedAt     DateTime?            @map("assigned_at")
  leadScore      Int                  @default(0) @map("lead_score")
  riskScore      Int                  @default(0) @map("risk_score")
  riskSignals    Json?                @default("[]") @map("risk_signals")
  authenticityScore Int               @default(0) @map("authenticity_score")
  lastActivityAt DateTime?            @default(now()) @map("last_activity_at")
  preferences    Json?                @default("{}")
  agentLeads     AgentLead[]
  bookings       Booking[]
  interactions   LeadInteraction[]
  property       Property?            @relation(fields: [propertyId], references: [id])
  tenant         Tenant?              @relation(fields: [tenantId], references: [id])
  unit           Unit?                @relation(fields: [unitId], references: [id])
  user           User?                @relation(fields: [userId], references: [id])
  enrollments    WorkflowEnrollment[]
  audienceGroups AudienceGroup[]      @relation("LeadAudienceGroups")
  lossData       LeadLossData?
  tasks          Task[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([userId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

model LeadLossData {
  id              String   @id @default(uuid()) @db.Uuid
  leadId          String   @unique @map("lead_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  primaryReason   String   @map("primary_reason")
  secondaryReason String?  @map("secondary_reason")
  stageAtLoss     String   @map("stage_at_loss") // "Enquiry", "Site Visit", "Negotiation", "Booking"
  lostImpactScore Decimal  @default(0) @map("lost_impact_score") @db.Decimal(15, 2)
  competitorName  String?  @map("competitor_name")
  notes           String?
  revivalStatus   Int      @default(1) @map("revival_status") // 1: None, 2: Queued, 3: Active, 4: Revived
  revivalDate     DateTime? @map("revival_date")
  createdAt       DateTime @default(now()) @map("created_at")

  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("lead_loss_data")
}

model WorkflowEnrollment {
  id           String            @id @default(uuid()) @db.Uuid
  workflowId   String            @map("workflow_id") @db.Uuid
  leadId       String            @map("lead_id") @db.Uuid
  currentStep  String?           @map("current_step")
  status       Int               @default(1)
  nextActionAt DateTime?         @map("next_action_at")
  enrolledAt   DateTime          @default(now()) @map("enrolled_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  lead         Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  workflow     MarketingWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  logs         WorkflowLog[]

  @@unique([workflowId, leadId])
  @@map("workflow_enrollments")
}

model WorkflowLog {
  id           String             @id @default(uuid()) @db.Uuid
  enrollmentId String             @map("enrollment_id") @db.Uuid
  stepId       String             @map("step_id")
  actionType   String
  status       String
  result       Json?
  occurredAt   DateTime           @default(now()) @map("occurred_at")
  tenantId     String?            @map("tenant_id") @db.Uuid
  enrollment   WorkflowEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  tenant       Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("workflow_logs")
}

model LeadInteraction {
  id          String   @id @default(uuid()) @db.Uuid
  leadId      String   @map("lead_id") @db.Uuid
  type        String
  metadata    Json?
  scoreWeight Int      @default(0) @map("score_weight")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  tenantId    String?  @map("tenant_id") @db.Uuid
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("lead_interactions")
}

model UserPropertyAccess {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @map("tenant_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  propertyId  String?   @map("property_id") @db.Uuid
  accessLevel Int?      @map("access_level")
  createdAt   DateTime  @default(now()) @map("created_at")
  property    Property? @relation(fields: [propertyId], references: [id])
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([propertyId])
  @@map("user_property_access")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String?
  entity    String?
  entityId  String?  @map("entity_id") @db.Uuid
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Media {
  id                 String     @id @default(uuid()) @db.Uuid
  tenantId           String?    @map("tenant_id") @db.Uuid
  userId             String?    @map("user_id") @db.Uuid
  filename           String?
  originalName       String?    @map("original_name")
  mimeType           String?    @map("mime_type")
  size               Int?
  url                String?
  alt                String?
  description        String?
  category           String?    @default("general")
  type               String?
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  tenant             Tenant?    @relation(fields: [tenantId], references: [id])
  user               User?      @relation(fields: [userId], references: [id])
  pageFeatureImages  Page[]     @relation("PageFeatureImage")
  propertyBrochures  Property[] @relation("PropertyBrochure")
  propertyFloorPlans Property[] @relation("PropertyFloorPlan")
  propertyMainImages Property[] @relation("PropertyMainImage")
  unitMainImages     Unit[]     @relation("UnitMainImage")

  @@index([tenantId])
  @@map("media")
}

model Module {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  slug          String         @unique
  description   String?
  status        Int            @default(1)
  createdAt     DateTime       @default(now()) @map("created_at")
  tenantModules TenantModule[]
  plans         Plan[]         @relation("ModuleToPlan")

  @@map("modules")
}

model TenantModule {
  tenantId  String   @map("tenant_id") @db.Uuid
  moduleId  String   @map("module_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  settings  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, moduleId])
  @@map("tenant_modules")
}

model Integration {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  platform    String    @default("wordpress")
  siteUrl     String    @map("site_url")
  siteName    String?   @map("site_name")
  apiKey      String    @unique @map("api_key")
  environment String    @default("production")
  isSandbox   Boolean   @default(false) @map("is_sandbox")
  status      Boolean   @default(true)
  lastSyncAt  DateTime? @map("last_sync_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("integrations")
}

model Widget {
  id            String    @id @default(uuid()) @db.Uuid
  uniqueId      String    @unique @map("unique_id")
  tenantId      String?   @map("tenant_id") @db.Uuid
  name          String
  type          String
  configuration Json
  status        Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  propertyId    String?   @map("property_id") @db.Uuid
  property      Property? @relation(fields: [propertyId], references: [id])
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@map("widgets")
}

model Website {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @unique
  customDomain  String?   @unique @map("custom_domain")
  tenantId      String?   @map("tenant_id") @db.Uuid
  propertyId    String?   @map("property_id") @db.Uuid
  propertyIds   String[]  @default([]) @map("property_ids")
